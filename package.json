{
  "name": "saw-protocol",
  "version": "1.0.0",
  "description": "SAW Protocol - Secure Atomic Wave: A Cryptographically Deterministic Token Launch Framework",
  "author": "Umair Abbas (trizist)",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "verify": "hardhat run scripts/verify.ts --network sepolia",
    "node": "hardhat node",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write '**/*.{ts,tsx,json,sol}'",
    "backend:dev": "cd backend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "clean": "hardhat clean && rm -rf cache artifacts typechain-types"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.0.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.3.0",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "ethers": "^6.16.0"
  }
}
