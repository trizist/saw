import random
import hashlib

NUM_USERS = 1000

users = [
    {
        "wallet": f"user_{i}",
        "amount": random.randint(1, 100)
    }
    for i in range(NUM_USERS)
]

entropy = "seed123"

def compute_order(user):
    return hashlib.sha256((entropy + user["wallet"]).encode()).hexdigest()

# Sort users by deterministic order
sorted_users = sorted(users, key=compute_order)

# Allocate proportionally
total = sum(u["amount"] for u in users)

allocations = []
for u in sorted_users:
    share = u["amount"] / total
    allocations.append(share)

# Metrics
print("Top 10 allocations:", sorted(allocations, reverse=True)[:10])
print("Gini approximation:", sum(allocations)/len(allocations))
