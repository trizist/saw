# ─── SAW Protocol Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Private key for deployment (without 0x prefix)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC endpoints
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://eth.llamarpc.com
ETH_RPC_URL=https://rpc.sepolia.org

# Etherscan verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# ─── Deployed Contract Addresses ──────────────────────────────────────────────
SAW_TOKEN_ADDRESS=
SAW_LAUNCH_ADDRESS=
SAW_ALLOCATOR_ADDRESS=
SAW_SETTLEMENT_ADDRESS=
SAW_GOVERNANCE_ADDRESS=

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Entropy sources
DRAND_API_URL=https://drand.cloudflare.com
DRAND_CHAIN_HASH=8990e7a9aaed2ffed73dbd7092123d6f289930540d7651336225dc172e51b2ce
BTC_RPC_URL=https://blockstream.info/api
NTP_SERVERS=pool.ntp.org,time.google.com,time.cloudflare.com

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_CHAIN_ID=11155111
VITE_BACKEND_URL=http://localhost:4000
VITE_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_SAW_LAUNCH_ADDRESS=
VITE_SAW_TOKEN_ADDRESS=
VITE_SAW_ALLOCATOR_ADDRESS=
VITE_SAW_SETTLEMENT_ADDRESS=
VITE_SAW_GOVERNANCE_ADDRESS=

# ─── IPFS / Arweave ───────────────────────────────────────────────────────────
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=
ARWEAVE_KEY=

# ─── Testing ──────────────────────────────────────────────────────────────────
REPORT_GAS=true
