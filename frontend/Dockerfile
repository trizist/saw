FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_CHAIN_ID=11155111
ARG VITE_BACKEND_URL=http://localhost:4000
ARG VITE_WALLET_CONNECT_PROJECT_ID=
ARG VITE_SAW_LAUNCH_ADDRESS=
ARG VITE_SAW_TOKEN_ADDRESS=
ARG VITE_SAW_ALLOCATOR_ADDRESS=
ARG VITE_SAW_SETTLEMENT_ADDRESS=
ENV VITE_CHAIN_ID=$VITE_CHAIN_ID
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL
ENV VITE_WALLET_CONNECT_PROJECT_ID=$VITE_WALLET_CONNECT_PROJECT_ID
ENV VITE_SAW_LAUNCH_ADDRESS=$VITE_SAW_LAUNCH_ADDRESS
ENV VITE_SAW_TOKEN_ADDRESS=$VITE_SAW_TOKEN_ADDRESS
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
