{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["warn", "^0.8.24"],
    "avoid-suicide": "error",
    "avoid-sha3": "warn",
    "no-unused-vars": "warn",
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "reason-string": ["warn", { "maxLength": 64 }],
    "custom-errors": "warn",
    "named-parameters-mapping": "off",
    "ordering": "warn"
  }
}
